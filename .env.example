# ==========================================================================
# Betfair LTD Bot — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# ==========================================================================

# --- Betfair API credentials (required for all deployments) ---
BETFAIR_APP_KEY=your_app_key_here
BETFAIR_USERNAME=your_betfair_username
BETFAIR_PASSWORD=your_betfair_password

# ==========================================================================
# SSL CERTS — choose the block that matches your deployment
# ==========================================================================

# [A] Local Python  (python -m src.main on your machine)
#     Absolute path to wherever you stored your Betfair SSL certs.
BETFAIR_CERT_PATH=C:/Users/you/.betfair/client-2048.crt
BETFAIR_CERT_KEY_PATH=C:/Users/you/.betfair/client-2048.key

# [B] Local Docker  (docker compose --profile bot up -d)
#     Copy certs to ./certs/betfair.crt and ./certs/betfair.key on the host.
#     docker-compose.yml mounts ./certs → /certs and overrides the paths below,
#     so you don't need to change anything here for this mode.
# BETFAIR_CERT_PATH=/certs/betfair.crt
# BETFAIR_CERT_KEY_PATH=/certs/betfair.key

# [C] Railway
#     Base64-encode your cert files and set the _B64 vars in Railway's UI.
#     scripts/start.sh decodes them to /tmp at startup; cert path vars are
#     set automatically — you don't need BETFAIR_CERT_PATH on Railway.
#
#     Encode on Windows PowerShell:
#       [Convert]::ToBase64String([IO.File]::ReadAllBytes("client-2048.crt"))
#       [Convert]::ToBase64String([IO.File]::ReadAllBytes("client-2048.key"))
#
# BETFAIR_CERT_B64=<base64-encoded .crt content>
# BETFAIR_CERT_KEY_B64=<base64-encoded .key content>

# ==========================================================================
# DATABASE
# ==========================================================================

# Docker Compose uses these to create the Postgres container
POSTGRES_PORT=5432
POSTGRES_DB=betfair_ltd
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot_password

# [A] Local Python — connects to localhost
DATABASE_URL=postgresql+psycopg2://bot:bot_password@localhost:5432/betfair_ltd
DATABASE_URL_SYNC=postgresql+psycopg2://bot:bot_password@localhost:5432/betfair_ltd

# [B] Local Docker — docker-compose.yml overrides DATABASE_URL automatically
#                    (host changes from localhost → postgres service name)
# [C] Railway       — Railway injects DATABASE_URL; start.sh normalises the format

# ==========================================================================
# OPTIONAL
# ==========================================================================

# --- API-Football (optional score confirmation feed) ---
# API_FOOTBALL_KEY=your_api_football_key

# --- Grafana ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
