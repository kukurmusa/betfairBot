# ==========================================================================
# Betfair LTD Bot — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
# ==========================================================================

# --- Betfair API ---
BETFAIR_APP_KEY=your_app_key_here
BETFAIR_USERNAME=your_betfair_username
BETFAIR_PASSWORD=your_betfair_password
BETFAIR_CERT_PATH=/path/to/client-2048.crt
BETFAIR_CERT_KEY_PATH=/path/to/client-2048.key

# --- PostgreSQL ---
# Used by Docker Compose AND the Python bot.
# The bot uses asyncpg; Alembic uses psycopg2.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=betfair_ltd
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot_password

# Connection string for bot runtime and Alembic migrations (psycopg2 driver)
DATABASE_URL=postgresql+psycopg2://bot:bot_password@localhost:5432/betfair_ltd

# Alembic also reads DATABASE_URL_SYNC if set; keep in sync with DATABASE_URL
DATABASE_URL_SYNC=postgresql+psycopg2://bot:bot_password@localhost:5432/betfair_ltd

# --- API-Football (optional score confirmation feed) ---
# API_FOOTBALL_KEY=your_api_football_key

# --- Dashboard API (Phase 5) ---
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8000

# --- Grafana (Phase 5) ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
